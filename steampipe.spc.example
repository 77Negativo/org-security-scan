# Steampipe Configuration Example
# Copy this file to ~/.steampipe/config/github.spc and configure with your credentials

connection "github" {
  plugin = "github"

  # GitHub Personal Access Token
  # Você pode obter em: https://github.com/settings/tokens
  # Scopes necessários: repo, admin:org (read), read:user
  token = "ghp_your_token_here"

  # Opcional: especificar organizações específicas
  # organizations = ["sua-organizacao"]

  # Opcional: limitar rate limit
  # max_rate = 100
}

# Conexão para múltiplas organizações (opcional)
# connection "github_org1" {
#   plugin = "github"
#   token  = "ghp_token_org1"
#   organizations = ["org1"]
# }

# connection "github_org2" {
#   plugin = "github"
#   token  = "ghp_token_org2"
#   organizations = ["org2"]
# }
